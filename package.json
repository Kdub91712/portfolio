{
  "name": "kevin_portfolio",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "acorn": "^7.2.0",
    "axios": "^1.7.0",
    "eslint-utils": "^2.0.0",
    "handlebars": "^4.7.6",
    "kind-of": "^6.0.3",
    "lodash": "^4.17.15",
    "lodash.template": "^4.5.0",
    "minimist": "^1.2.5",
    "sass": "^1.77.0",
    "prop-types": "^15.7.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-ga": "^2.7.0",
    "react-scripts": "5.0.1",
    "serialize-javascript": "^3.0.0",
    "serve": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  },
  "scripts": {
    "dev": "react-scripts start",
    "start": "serve -s build",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "eject": "react-scripts eject",
    "heroku-postbuild": "yarn run build",
    "docker:build": "docker build --platform linux/amd64 -f Dockerfile.prod -t registry.heroku.com/kevin-wilson-portfolio-docker/web .",
    "docker:push": "docker push registry.heroku.com/kevin-wilson-portfolio-docker/web",
    "docker:release": "heroku container:release -a kevin-wilson-portfolio-docker web",
    "deploy": "yarn docker:build && yarn docker:push && yarn docker:release"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "resolutions": {
    "underscore": "^1.13.7"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
